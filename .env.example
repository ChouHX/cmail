# Public site settings
BASE_URL=https://mail.example.com
MAIL_DOMAINS=example.com

# Admin account (change all values before deployment)
ADMIN_USER=admin
ADMIN_PASSWORD=replace-with-a-strong-password
FLASK_SECRET=replace-with-a-long-random-value

# Must match the Cloudflare Worker's INGEST_SECRET
INGEST_SECRET=replace-with-a-long-random-value

# Host-only port used by the 1Panel reverse proxy
APP_PORT=8000

# Optional application settings
DEFAULT_MESSAGE_LIMIT=100
CLEANUP_INTERVAL_SECONDS=60
